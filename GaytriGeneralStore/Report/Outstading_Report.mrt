        <Name>View_Outstanding_Report_Gayatry</Name>
        <NameInSource>Connection</NameInSource>
        <Parameters isList="true" count="0" />
        <SqlCommand>select *,DATEDIFF(DAY, InvoiceDate, GETDATE()) AS DueDays,SUM(ISNULL(BillAmt,0) - ISNULL(DrAmt,0)) OVER (PARTITION BY LedgerId ORDER BY InvoiceDate, InvoiceNo ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS Balance from View_Outstanding_Report_Gayatry</SqlCommand>
      </View_Outstanding_Report_Gayatry>
